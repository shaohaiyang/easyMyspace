[
  {
    "context": "Workspace",
    "bindings": {
      // =============================================================
      // Ctrl+Z 前缀键体系 — 与 Kitty 完全统一
      // =============================================================

      // --- 分屏 ---
      "ctrl-z u": "pane::SplitRight",
      "ctrl-z v": "pane::SplitDown",

      // --- 新建终端（对应 Kitty 的 new tab） ---
      "ctrl-z /": "workspace::NewTerminal",

      // --- 循环切换分屏焦点 ---
      "ctrl-z ctrl-z": "pane::ActivateNextItem",

      // --- 重载配置 ---
      "ctrl-z r": "workspace::Reload",

      // --- Tab 切换 ---
      "ctrl-z b": "pane::ActivatePrevItem",
      "ctrl-z a": "pane::ActivateNextItem",

      // --- Vim 风格分屏方向移动 (与 Kitty neighboring_window 一致) ---
      "ctrl-z h": "workspace::ActivatePaneLeft",
      "ctrl-z j": "workspace::ActivatePaneDown",
      "ctrl-z k": "workspace::ActivatePaneUp",
      "ctrl-z l": "workspace::ActivatePaneRight",

      // --- 关闭当前分屏 ---
      "ctrl-z w": "pane::CloseActiveItem",

      // --- 全屏放大 ---
      "ctrl-z z": "workspace::ToggleZoom",

      // --- 快速面板 ---
      "ctrl-z e": "file_finder::Toggle",               // 文件搜索（对应 Kitty yazi）
      "ctrl-z o": "agent::ToggleFocus",                 // AI 助手（对应 Kitty opencode）
      "ctrl-z g": "git_panel::ToggleFocus",            // Git 面板（对应 Kitty lazygit）
      "ctrl-z ctrl-f": "project_panel::ToggleFocus",   // 项目文件树
      "ctrl-z `": "terminal_panel::ToggleFocus",       // 终端面板

      // --- 额外增强绑定 (与 Kitty 统一) ---
      "ctrl+shift+enter": "workspace::NewTerminal",
      "ctrl+shift+right": "pane::ActivateNextItem",
      "ctrl+shift+left": "pane::ActivatePrevItem",

      // --- Dock 面板切换 ---
      "ctrl-1": "workspace::ToggleLeftDock",
      "ctrl-2": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-enter": "assistant::InlineAssist",
      "cmd-shift-enter": "agent::ToggleFocus",
      "alt-\\": "editor::ToggleCodeActions",
      "alt-/": "editor::ToggleComments",
      "alt-up": "editor::MoveLineUp",
      "alt-down": "editor::MoveLineDown",
      "cmd-d": "editor::SelectNext",
      "cmd-shift-d": "editor::SelectPrevious",
      "ctrl-w": "editor::SelectLargerSyntaxNode",
      "ctrl-shift-w": "editor::SelectSmallerSyntaxNode"
    }
  }
]
