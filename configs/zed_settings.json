{
  "theme": "Catppuccin Mocha",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_features": {
    "calt": true,
    "liga": true
  },
  "relative_line_numbers": true,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "tab_size": 2,
  "show_whitespaces": "boundary",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "format_on_save": "on",
  "show_inline_completions": true,
  "inline_completions": {
    "disabled_globs": [".env*"]
  },
  "features": {
    "inline_completion_provider": "copilot"
  },
  "languages": {
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "auto"
    },
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "Go": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "preferred_line_length": 100
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on"
    }
  },
  "assistant": {
    "enabled": true,
    "version": "2",
    "default_openai_api_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
    "default_model": {
      "provider": "openai",
      "model": "glm-4.7"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 13,
    "blinking": "off",
    "env": {
      "TERM": "xterm-256color"
    }
  },
  "project_panel": {
    "file_icons": true,
    "git_status": true,
    "indent_size": 2
  },
  "dock": "right",
  "scrollbar": {
    "show": "never"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": true,
        "inlayHints": {
          "typeHints": true,
          "parameterHints": true,
          "chainingHints": true
        }
      }
    }
  }
}
